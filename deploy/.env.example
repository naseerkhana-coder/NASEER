# MAXEK ERP — Production environment (copy to .env on VPS)
MAXEK_SECRET_KEY=change-this-to-a-long-random-string
FLASK_ENV=production
MAXEK_HOST=127.0.0.1
MAXEK_PORT=8000
MAXEK_WORKERS=2

# OpenAI — AI features (DPR writer, project assistant, BOQ search, document reader)
# Create key: https://platform.openai.com/api-keys
# Billing must be active: https://platform.openai.com/settings/organization/billing
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
