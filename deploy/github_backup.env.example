# Copy to github_backup.env on the VPS (never commit github_backup.env)
# chmod 600 deploy/github_backup.env

# REQUIRED — use a PRIVATE GitHub repository
# SSH (recommended on VPS):
MAXEK_GITHUB_REPO=git@github.com:naseerkhana-coder/MAXEK_ERP-.git
# HTTPS + token alternative:
# MAXEK_GITHUB_REPO=https://github.com/naseerkhana-coder/MAXEK_ERP-.git
# export GITHUB_TOKEN=ghp_xxxxxxxx

MAXEK_GITHUB_BRANCH=vps-backups
MAXEK_BACKUP_WORKDIR=/var/www/maxek_erp/.github_backup_repo

# 1 = include SQLite database (recommended for full restore)
MAXEK_BACKUP_INCLUDE_DB=1

# 0 = do NOT upload .env (recommended). Set 1 only if repo is private and you accept the risk.
MAXEK_BACKUP_INCLUDE_ENV=0

# 1 = include uploaded documents (static/uploads)
MAXEK_BACKUP_INCLUDE_UPLOADS=1

MAXEK_GIT_USER_NAME=MAXEK VPS Backup
MAXEK_GIT_USER_EMAIL=backup@maxek.local
